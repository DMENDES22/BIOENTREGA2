{
  "entities": {
    "GPSLocation": {
      "title": "GPSLocation",
      "description": "Defines GPS coordinate collection structure for proof of delivery/events",
      "type": "object",
      "properties": {
        "latitude": {
          "type": "number",
          "description": "Latitude coordinate of driver location"
        },
        "longitude": {
          "type": "number",
          "description": "Longitude coordinate of driver location"
        },
        "accuracy": {
          "type": "number",
          "description": "GPS accuracy radius in meters"
        }
      },
      "required": ["latitude", "longitude"]
    },
    "DeliveryOccurrence": {
      "title": "DeliveryOccurrence",
      "description": "Incident or progression log recorded for a delivery document",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique key identifier"
        },
        "status": {
          "type": "string",
          "enum": ["PENDENTE", "EM_ROTA", "ENTREGUE", "PROBLEMA"]
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "location": {
          "$ref": "#/definitions/GPSLocation"
        },
        "receiverName": {
          "type": "string"
        },
        "photo": {
          "type": "string",
          "description": "Base64 signature or photoproof"
        },
        "notes": {
          "type": "string"
        }
      },
      "required": ["id", "status", "timestamp"]
    },
    "Delivery": {
      "title": "Delivery",
      "description": "Represents an internal shipping delivery dispatch",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Autogenerated ID"
        },
        "invoiceNumber": {
          "type": "string",
          "description": "Número da Nota Fiscal (NF)"
        },
        "volumes": {
          "type": "number",
          "description": "Número de volumes carregados"
        },
        "clientName": {
          "type": "string",
          "description": "Nome do local de recebimento"
        },
        "address": {
          "type": "string",
          "description": "Endereço físico de entrega"
        },
        "observations": {
          "type": "string",
          "description": "Instruções extras de trânsito"
        },
        "status": {
          "type": "string",
          "enum": ["PENDENTE", "EM_ROTA", "ENTREGUE", "PROBLEMA"]
        },
        "assignedDriver": {
          "type": "string",
          "description": "Nome ou e-mail de identificação do motorista"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Data de registro inicial"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        },
        "completedAt": {
          "type": "string",
          "format": "date-time"
        },
        "receiverName": {
          "type": "string",
          "description": "Nome do recebedor na baixa"
        },
        "photo": {
          "type": "string",
          "description": "Foto de comprovante anexada (Base64)"
        },
        "gpsLocation": {
          "$ref": "#/definitions/GPSLocation"
        },
        "occurrences": {
          "type": "array",
          "description": "Lista de ocorrências"
        }
      },
      "required": ["invoiceNumber", "volumes", "clientName", "address", "status", "createdAt", "updatedAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile with role details",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "email": {
          "type": "string"
        },
        "role": {
          "type": "string",
          "enum": ["ADMIN", "DRIVER"]
        }
      },
      "required": ["uid", "name", "email", "role"]
    }
  },
  "firestore": {
    "/deliveries/{deliveryId}": {
      "schema": "Delivery",
      "description": "Collection of all shipping deliveries"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Profile information and permissions for BioEntregas users"
    }
  }
}
